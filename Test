<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phiên Đấu Giá Thời Gian - Gen Z & Deadline</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; background-color: #0f172a; color: white; }
        .card { transition: all 0.3s ease; border: 1px solid #1e293b; }
        .card:hover { transform: translateY(-5px); border-color: #38bdf8; }
        .burnout { color: #f43f5e; text-shadow: 0 0 10px rgba(244, 63, 94, 0.5); }
        .progress-bar { transition: width 0.5s ease-in-out; }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="sticky top-0 z-50 bg-[#0f172a]/90 backdrop-blur-md pb-4 border-b border-slate-700 mb-8">
        <div class="flex justify-between items-center max-w-5xl mx-auto">
            <div>
                <h1 class="text-2xl font-black text-sky-400">TIME AUCTION</h1>
                <p class="text-xs text-slate-400">Gen Z: Đang chạy hay đang kiệt sức?</p>
            </div>
            <div class="text-right">
                <p class="text-sm font-bold uppercase tracking-widest text-slate-400">Ví Năng Lượng</p>
                <div id="energy-display" class="text-4xl font-black text-white">100<span class="text-lg text-sky-400">đ</span></div>
            </div>
        </div>
        <div class="max-w-5xl mx-auto mt-4 bg-slate-800 h-3 rounded-full overflow-hidden">
            <div id="progress-bar" class="progress-bar bg-sky-500 h-full w-full"></div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="item-grid">
        </div>

    <div class="max-w-5xl mx-auto mt-12 bg-slate-900 p-6 rounded-2xl border border-slate-700">
        <h2 class="text-xl font-bold mb-4 flex items-center">
            <span class="mr-2">📝</span> Danh sách vật phẩm đã mua
        </h2>
        <div id="purchase-list" class="space-y-2 text-slate-400 mb-6">
            <p>Chưa có vật phẩm nào được chọn...</p>
        </div>
        <div id="burnout-warning" class="hidden p-4 bg-rose-500/10 border border-rose-500 rounded-xl">
            <p class="burnout font-bold text-center italic">CẢNH BÁO: BẠN ĐANG TRẠM NGƯỠNG KIỆT SỨC (BURNOUT)! <br>Bạn đang vay mượn sức khỏe để đổi lấy những thành tựu này.</p>
        </div>
    </div>

    <script>
        let energy = 100;
        const items = [
            { id: 1, name: "IELTS 8.0 / Hạng Xuất Sắc", price: 35, icon: "🎓", cost: "Mất 400 giờ học áp lực & thức khuya." },
            { id: 2, name: "Lương 20 triệu + Freelance", price: 45, icon: "💰", cost: "Mất tự do, rủi ro stress kéo dài." }, { id: 3, name: "Body 'Vạn Người Mê'", price: 25, icon: "🏋️", cost: "Ăn kiêng khắt khe & 2h tập mỗi ngày." },
            { id: 4, name: "KOL 100k Followers", price: 30, icon: "📱", cost: "Sống dưới ánh nhìn & phán xét của MXH." },
            { id: 5, name: "Quan Hệ Xã Hội Rộng", price: 20, icon: "🤝", cost: "Kiệt sức vì hướng ngoại giả tạo." },
            { id: 6, name: "Cập nhật mọi Trend/Drama", price: 15, icon: "🔥", cost: "Não bộ quá tải thông tin rác." },
            { id: 7, name: "8 Tiếng Ngủ & Bình Yên", price: 20, icon: "🌙", cost: "Có thể bỏ lỡ một vài cơ hội ngắn hạn." },
            { id: 8, name: "Hào Quang 'Con Nhà Người Ta'", price: 40, icon: "🌟", cost: "Áp lực phải luôn hoàn hảo 24/7." }
        ];

        let purchased = [];

        function renderItems() {
            const grid = document.getElementById('item-grid');
            grid.innerHTML = items.map(item => `
                <div class="card bg-slate-900 p-6 rounded-2xl flex flex-col justify-between">
                    <div>
                        <div class="text-4xl mb-4">${item.icon}</div>
                        <h3 class="text-lg font-bold mb-1">${item.name}</h3>
                        <p class="text-sky-400 font-black text-xl mb-4">${item.price}đ</p>
                    </div>
                    <button onclick="buyItem(${item.id})" id="btn-${item.id}" 
                        class="w-full bg-slate-800 hover:bg-sky-600 py-3 rounded-xl font-bold transition-colors">
                        MUA NGAY
                    </button>
                </div>
            `).join('');
        }

        function buyItem(id) {
            const item = items.find(i => i.id === id);
            const btn = document.getElementById(`btn-${id}`);

            if (purchased.includes(id)) {
                // Hoàn tác
                energy += item.price;
                purchased = purchased.filter(itemId => itemId !== id);
                btn.innerText = "MUA NGAY";
                btn.classList.replace('bg-sky-600', 'bg-slate-800');
            } else {
                // Mua
                energy -= item.price;
                purchased.push(id);
                btn.innerText = "ĐÃ SỞ HỮU";
                btn.classList.replace('bg-slate-800', 'bg-sky-600');
            }

            updateUI();
        }

        function updateUI() {
            const display = document.getElementById('energy-display');
            const progress = document.getElementById('progress-bar');
            const list = document.getElementById('purchase-list');
            const warning = document.getElementById('burnout-warning');

            display.innerHTML = `${energy}<span class="text-lg text-sky-400">đ</span>`;
            
            // Cập nhật thanh năng lượng
            let percent = Math.max(0, energy);
            progress.style.width = percent + "%"; if (energy < 0) {
                display.classList.add('burnout');
                progress.classList.replace('bg-sky-500', 'bg-rose-500');
                warning.classList.remove('hidden');
            } else {
                display.classList.remove('burnout');
                progress.classList.replace('bg-rose-500', 'bg-sky-500');
                warning.classList.add('hidden');
            }

            // Cập nhật danh sách tóm tắt
            if (purchased.length === 0) {
                list.innerHTML = "<p>Chưa có vật phẩm nào được chọn...</p>";
            } else {
                list.innerHTML = purchased.map(id => {
                    const item = items.find(i => i.id === id);
                    return `<div class="flex justify-between border-b border-slate-800 pb-2">
                                <span>${item.icon} ${item.name}</span>
                                <span class="text-rose-400 text-sm italic">${item.cost}</span>
                            </div>`;
                }).join('');
            }
        }

        renderItems();
    </script>
</body>
</html>
